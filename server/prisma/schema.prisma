generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String            @id @default(cuid())
  email           String            @unique
  name            String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  clerkId         String            @unique
  username        String?           @unique
  bio             String?           @db.VarChar(300)
  avatarUrl       String?
  bidsPlaced      Bid[]             @relation("BuyerBids")
  creditBalance   CreditBalance?
  creditPurchases CreditPurchase[]
  giftCards       GiftCard[]
  listings        Listing[]
  payouts         Payout[]
  reviewsReceived Review[]          @relation("ReviewsReceived")
  reviewsGiven    Review[]          @relation("ReviewsGiven")
  tradesAsBuyer   Trade[]           @relation("BuyerTrades")
  tradesAsSeller  Trade[]           @relation("SellerTrades")
  verification    UserVerification?
  stripeAccountId String?
}

model GiftCard {
  id              String         @id @default(cuid())
  userId          String?
  brand           String
  cardNumber      String
  pin             String
  balance         Float
  faceValue       Float
  status          GiftCardStatus @default(PENDING)
  source          GiftCardSource @default(USER)
  vendorId        String?
  verifiedAt      DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  description     String?
  revealed        Boolean        @default(false)
  autoVerified    Boolean        @default(false)
  rejectionReason String?
  user            User?          @relation(fields: [userId], references: [id])
  vendor          Vendor?        @relation(fields: [vendorId], references: [id])
  listing         Listing?
}

model Listing {
  id                String        @id @default(cuid())
  userId            String
  giftCardId        String        @unique
  status            ListingStatus @default(PENDING_VERIFICATION)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  acceptsExchange   Boolean       @default(false)
  buyNowPrice       Float?
  minAcceptPrice    Float?
  preferredMinValue Float?
  preferredBrand    String[]
  bids              Bid[]
  giftCard          GiftCard      @relation(fields: [giftCardId], references: [id])
  user              User          @relation(fields: [userId], references: [id])
  trade             Trade?
}

model Bid {
  id            String    @id @default(cuid())
  listingId     String
  bidderId      String
  bidType       BidType
  cashAmount    Float?
  offeredCardId String?
  status        BidStatus @default(PENDING)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  bidder        User      @relation("BuyerBids", fields: [bidderId], references: [id])
  listing       Listing   @relation(fields: [listingId], references: [id])
  trade         Trade?
}

model Trade {
  id         String      @id @default(cuid())
  listingId  String      @unique
  bidId      String?     @unique
  sellerId   String
  buyerId    String
  tradeType  TradeType
  finalPrice Float?
  status     TradeStatus @default(PENDING)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  reviews    Review[]
  bid        Bid?        @relation(fields: [bidId], references: [id])
  buyer      User        @relation("BuyerTrades", fields: [buyerId], references: [id])
  listing    Listing     @relation(fields: [listingId], references: [id])
  seller     User        @relation("SellerTrades", fields: [sellerId], references: [id])
  stripePaymentIntentId String?
  stripeTransferId      String?
}

model CreditBalance {
  id        String   @id @default(cuid())
  userId    String   @unique
  balance   Float    @default(0)
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
}

model CreditPurchase {
  id        String               @id @default(cuid())
  userId    String
  amount    Float
  status    CreditPurchaseStatus @default(PENDING)
  method    PayoutMethod
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  user      User                 @relation(fields: [userId], references: [id])
}

model Payout {
  id          String       @id @default(cuid())
  userId      String
  amount      Float
  status      PayoutStatus @default(PENDING)
  method      PayoutMethod
  destination String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  user        User         @relation(fields: [userId], references: [id])
}

model Review {
  id         String   @id @default(cuid())
  tradeId    String
  reviewerId String
  revieweeId String
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())
  reviewee   User     @relation("ReviewsReceived", fields: [revieweeId], references: [id])
  reviewer   User     @relation("ReviewsGiven", fields: [reviewerId], references: [id])
  trade      Trade    @relation(fields: [tradeId], references: [id])
}

model UserVerification {
  id        String             @id @default(cuid())
  userId    String             @unique
  status    VerificationStatus @default(PENDING)
  method    String?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  user      User               @relation(fields: [userId], references: [id])
}

model Vendor {
  id        String       @id @default(cuid())
  name      String
  contact   String?
  status    VendorStatus @default(PENDING)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  giftCards GiftCard[]
}

enum GiftCardStatus {
  PENDING
  VERIFIED
  AVAILABLE
  RESERVED
  TRADED
  CASHED_OUT
  FLAGGED
  FAILED
  DRAFT
}

enum GiftCardSource {
  USER
  VENDOR
  LYANTA
}

enum ListingStatus {
  PENDING_VERIFICATION
  ACTIVE
  RESERVED
  COMPLETED
  CANCELLED
}

enum BidType {
  CASH
  EXCHANGE
}

enum BidStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
  CANCELLED
}

enum TradeType {
  CASH
  EXCHANGE
  CREDITS
}

enum TradeStatus {
  PENDING
  COMPLETED
  FAILED
  DISPUTED
}

enum PayoutStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum PayoutMethod {
  ACH
  CRYPTO
  PAYPAL
  MONEY_ORDER
}

enum CreditPurchaseStatus {
  PENDING
  COMPLETED
  FAILED
}

enum VendorStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}
